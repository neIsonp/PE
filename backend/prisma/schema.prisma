generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum AuditAction {
  AUTH_REGISTER
  AUTH_LOGIN_SUCCESS
  AUTH_LOGIN_FAILURE
  USER_ROLE_UPDATED
  EVENT_CREATED
  EVENT_UPDATED
  EVENT_DELETED
}

enum ContactMessageStatus {
  PENDING
  READ
  ARCHIVED
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String
  role         UserRole   @default(USER)
  bio          String?
  institution  String?
  avatarUrl    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  events       Event[]
  auditLogs    AuditLog[] @relation("AuditActor")

  @@index([role, createdAt])
  @@map("users")
}

model Event {
  id          String   @id @default(cuid())
  title       String
  date        String
  time        String
  location    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([date, time])
  @@index([createdById, createdAt])
  @@map("events")
}

model ContactMessage {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String
  message   String
  status    ContactMessageStatus @default(PENDING)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([status, createdAt])
  @@map("contact_messages")
}

model NewsletterSubscription {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("newsletter_subscriptions")
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  actorId    String?
  actorEmail String?
  actor      User?       @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  targetId   String?
  targetType String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@index([targetType, targetId])
  @@map("audit_logs")
}
